{
  "_version": "1.83.0",
  "sap.app": {
    "id": "myproject",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "89b6277c-52e2-4aeb-9993-2764c4c99895"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/cases-collective/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.tnt": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "myproject.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "myproject.view",
        "async": true,
        "viewPath": "myproject.view"
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": "",
          "target": [
            "TargetDashboard"
          ]
        },
        {
          "name": "RouteDashboard",
          "pattern": "Dashboard",
          "target": [
            "TargetDashboard"
          ]
        },
        {
          "name": "RouteModality",
          "pattern": "Modality",
          "target": [
            "TargetModality"
          ]
        },
        {
          "name": "RouteServiceOrder",
          "pattern": "ServiceOrder",
          "target": [
            "TargetServiceOrder"
          ]
        },
        {
          "name": "RouteCases",
          "pattern": "Cases",
          "target": [
            "TargetCases"
          ]
        }
      ],
      "targets": {
        "TargetDashboard": {
          "id": "Dashboard",
          "name": "Dashboard"
        },
        "TargetModality": {
          "id": "Modality",
          "name": "Modality"
        },
        "TargetServiceOrder": {
          "id": "ServiceOrder",
          "name": "ServiceOrder"
        },
        "TargetCases": {
          "id": "Cases",
          "name": "Cases"
        }
      }
    },
    "rootView": {
      "viewName": "myproject.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
