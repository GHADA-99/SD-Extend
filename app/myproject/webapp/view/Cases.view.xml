<mvc:View
    controllerName="myproject.controller.Cases"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core">

    <Page id="CasesPage" title="{i18n>casesTitle}"
        titleAlignment="Center"
        showNavButton="true"
        navButtonPress="onNavBack">

        <content>
            <ScrollContainer id="_IDGenScrollContainer2" height="100%" vertical="true" horizontal="false">
                <VBox id="_IDGenVBox9" class="sapUiMediumMargin">

                    <!-- ─── Filter Card ─── -->
                    <f:Card id="_IDGenCard" class="sapUiSmallMarginBottom" width="100%">
                        <f:header>
                            <card:Header id="_IDGenHeader2"
                                title="{i18n>filterTitle}"
                                subtitle="{i18n>casesFilterSubtitle}"
                                iconSrc="sap-icon://filter"
                                iconDisplayShape="Square"
                                iconBackgroundColor="Accent1"/>
                        </f:header>
                        <f:content>
                            <VBox id="_IDGenVBox10" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                                <HBox id="_IDGenHBox1" wrap="Wrap" alignItems="End">

                                    <!-- Exam Code -->
                                    <VBox id="_IDGenVBox11" class="sapUiSmallMarginEnd sapUiSmallMarginTop">
                                        <Label id="_IDGenLabel6" text="{i18n>colExamCode}" labelFor="examCodeFilter"/>
                                        <SearchField
                                            id="examCodeFilter"
                                            width="14rem"
                                            placeholder="{i18n>searchExamCode}"
                                            search="onFilter"
                                            liveChange="onFilter"/>
                                    </VBox>

                                    <!-- Modality ID -->
                                    <VBox id="_IDGenVBox12" class="sapUiSmallMarginEnd sapUiSmallMarginTop">
                                        <Label id="_IDGenLabel7" text="{i18n>filterModality}" labelFor="modalityIDFilter"/>
                                        <ComboBox
                                            id="modalityIDFilter"
                                            width="16rem"
                                            placeholder="{i18n>allModalities}"
                                            selectionChange="onFilter"
                                            change="onFilter"
                                            items="{path: '/Modalities', templateShareable: false}">
                                            <core:ListItem id="_IDGenListItem2"
                                                key="{modalityID}"
                                                text="{modalityID} · {modalityDescription}"/>
                                        </ComboBox>
                                    </VBox>

                                    <!-- Modality Group -->
                                    <VBox id="_IDGenVBox13" class="sapUiSmallMarginEnd sapUiSmallMarginTop">
                                        <Label id="_IDGenLabel8" text="{i18n>filterGroup}" labelFor="modalityGroupFilter"/>
                                        <ComboBox
                                            id="modalityGroupFilter"
                                            width="16rem"
                                            placeholder="{i18n>allGroups}"
                                            selectionChange="onFilter"
                                            change="onFilter"
                                            items="{path: '/ModalityGroups', templateShareable: false}">
                                            <core:ListItem id="_IDGenListItem3"
                                                key="{modalityGroupID}"
                                                text="{modalityGroupID} · {modalityGroupDescription}"/>
                                        </ComboBox>
                                    </VBox>

                                    <!-- Creation Date -->
                                    <VBox id="_IDGenVBox14" class="sapUiSmallMarginEnd sapUiSmallMarginTop">
                                        <Label id="_IDGenLabel9" text="{i18n>colCreationDate}" labelFor="dateFilter"/>
                                        <DatePicker
                                            id="dateFilter"
                                            width="14rem"
                                            displayFormat="dd/MM/yyyy"
                                            valueFormat="yyyy-MM-dd"
                                            placeholder="DD/MM/YYYY"
                                            change="onFilter"/>
                                    </VBox>

                                    <!-- Reset -->
                                    <VBox id="_IDGenVBox15" class="sapUiSmallMarginTop">
                                        <Button id="_IDGenButton"
                                            text="{i18n>resetFilters}"
                                            icon="sap-icon://clear-filter"
                                            type="Transparent"
                                            press="onResetFilters"/>
                                    </VBox>

                                </HBox>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- ─── Results Card ─── -->
                    <f:Card id="_IDGenCard3" width="100%">
                        <f:header>
                            <card:Header id="_IDGenHeader3"
                                title="{i18n>casesResultsTitle}"
                                subtitle="{i18n>casesResultsSubtitle}"
                                iconSrc="sap-icon://list"
                                iconDisplayShape="Square"
                                iconBackgroundColor="Accent3"/>
                        </f:header>
                        <f:content>
                            <Table
                                id="casesTable"
                                items="{path: '/Cases'}"
                                noDataText="{i18n>noCases}"
                                growing="true"
                                growingThreshold="10"
                                fixedLayout="false">

                                <columns>
                                    <Column id="_IDGenColumn2">
                                        <Text id="_IDGenText3" text="{i18n>colExamCode}"/>
                                    </Column>
                                    <Column id="_IDGenColumn3">
                                        <Text id="_IDGenText4" text="{i18n>colDescEN}"/>
                                    </Column>
                                    <Column id="_IDGenColumn4">
                                        <Text id="_IDGenText5" text="{i18n>colDescAR}"/>
                                    </Column>
                                    <Column id="_IDGenColumn5" hAlign="End">
                                        <Text id="_IDGenText6" text="{i18n>colPrice}"/>
                                    </Column>
                                    <Column id="_IDGenColumn6">
                                        <Text id="_IDGenText7" text="{i18n>colCreationDate}"/>
                                    </Column>
                                    <Column id="_IDGenColumn7">
                                        <Text id="_IDGenText8" text="{i18n>filterModality}"/>
                                    </Column>
                                    <Column id="_IDGenColumn8">
                                        <Text id="_IDGenText9" text="{i18n>filterGroup}"/>
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem1" type="Inactive">
                                        <cells>
                                            <ObjectIdentifier id="_IDGenObjectIdentifier1" title="{examCode}"/>
                                            <Text id="_IDGenText10" text="{descriptionInEnglish}"/>
                                            <Text id="_IDGenText11" text="{descriptionInArabic}"/>
                                            <ObjectNumber id="_IDGenObjectNumber"
                                                number="{priceWithoutTax}"
                                                unit="SAR"/>
                                            <Text id="_IDGenText12" text="{
                                                path: 'creationData',
                                                type: 'sap.ui.model.odata.type.Date',
                                                formatOptions: { style: 'medium' }
                                            }"/>
                                            <ObjectStatus id="_IDGenObjectStatus"
                                                text="{modalityID}"
                                                state="Information"/>
                                            <ObjectStatus id="_IDGenObjectStatus1"
                                                text="{modalityGroup}"
                                                state="Success"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>

                            </Table>
                        </f:content>
                    </f:Card>

                </VBox>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
