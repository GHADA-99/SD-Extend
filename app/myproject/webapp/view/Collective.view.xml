<mvc:View
    controllerName="myproject.controller.Collective"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Page id="CollectivePage"
        title="{i18n>collectiveTitle}"
        titleAlignment="Center"
        showNavButton="true"
        navButtonPress="onNavBack">

        <!-- ─── Footer Action Bar ─── -->
        <footer>
            <OverflowToolbar id="collFooter">
                <ToolbarSpacer id="collFooterSpacer"/>
                <Button id="collGetCasesBtn"
                    text="{i18n>getCases}"
                    icon="sap-icon://clinical-order"
                    type="Default"
                    press="onGetCases"/>
                <Button id="collCalcBtn"
                    text="{i18n>calculateDiscount}"
                    icon="sap-icon://percentage"
                    type="Emphasized"
                    enabled="{= !${mode>/isCreate} || ${mode>/pkgSelected} }"
                    press="onCalculateDiscount"/>
                <Button id="collCreateBtn"
                    text="{i18n>save}"
                    icon="sap-icon://save"
                    type="Accept"
                    enabled="{calc>/calculated}"
                    press="onCreateServiceOrder"/>
            </OverflowToolbar>
        </footer>

        <content>
            <ScrollContainer id="collScroll" height="100%" vertical="true" horizontal="false">
                <VBox id="collVBox" class="sapUiMediumMargin">

                    <!-- ─── Card 1: Package Identity ─── -->
                    <f:Card id="collInfoCard" class="sapUiSmallMarginBottom" width="100%">
                        <f:header>
                            <card:Header id="collInfoHeader"
                                title="{examCode}"
                                subtitle="{descriptionInEnglish}"
                                iconSrc="sap-icon://document-text"
                                iconDisplayShape="Square"
                                iconBackgroundColor="Accent5"/>
                        </f:header>
                        <f:content>
                            <VBox id="collInfoContent" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                                <MessageStrip id="collCreateHint"
                                    text="{i18n>selectModalityHint}"
                                    type="Information"
                                    showCloseButton="false"
                                    class="sapUiSmallMarginBottom"
                                    visible="{= ${mode>/isCreate} &amp;&amp; !${mode>/pkgSelected} }"/>
                                <HBox id="collInfoHBox" wrap="Wrap" alignItems="Start"
                                    visible="{= !${mode>/isCreate} || ${mode>/pkgSelected} }">

                                    <VBox id="collDescArVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="18rem">
                                        <Label id="collDescArLabel" text="{i18n>colDescAR}" design="Bold"/>
                                        <Text id="collDescArText" text="{descriptionInArabic}"/>
                                    </VBox>

                                    <VBox id="collModalityVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                        <Label id="collModalityLabel" text="{i18n>filterModality}" design="Bold"/>
                                        <ObjectStatus id="collModalityStatus" text="{modalityID}" state="Information"/>
                                    </VBox>

                                    <VBox id="collGroupVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="12rem">
                                        <Label id="collGroupLabel" text="{i18n>filterGroup}" design="Bold"/>
                                        <ObjectStatus id="collGroupStatus" text="{modalityGroup}" state="Success"/>
                                    </VBox>

                                    <VBox id="collQtyVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                        <Label id="collQtyLabel" text="{i18n>colTotalQty}" design="Bold"/>
                                        <ObjectNumber id="collQtyNumber" number="{totalQtyPerModality}" unit="units"/>
                                    </VBox>

                                    <VBox id="collPriceVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="12rem">
                                        <Label id="collPriceLabel" text="{i18n>colPrice}" design="Bold"/>
                                        <ObjectNumber id="collPriceNumber" number="{priceWithoutTax}" unit="SAR" state="Success"/>
                                    </VBox>

                                    <VBox id="collDateVBox" class="sapUiSmallMarginBottom" width="12rem">
                                        <Label id="collDateLabel" text="{i18n>colCreationDate}" design="Bold"/>
                                        <Text id="collDateText" text="{
                                            path: 'creationData',
                                            type: 'sap.ui.model.odata.type.Date',
                                            formatOptions: { style: 'medium' }
                                        }"/>
                                    </VBox>

                                </HBox>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- ─── Card 2: Discount Calculation ─── -->
                    <f:Card id="collCalcCard" width="100%">
                        <f:header>
                            <card:Header id="collCalcHeader"
                                title="{i18n>collectiveCalcTitle}"
                                subtitle="{i18n>collectiveCalcSubtitle}"
                                iconSrc="sap-icon://percentage"
                                iconDisplayShape="Square"
                                iconBackgroundColor="Accent4"/>
                        </f:header>
                        <f:content>
                            <VBox id="collCalcContent" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">

                                <!-- Hint strip shown before calculation -->
                                <MessageStrip id="collCalcHint"
                                    text="{i18n>calcHintText}"
                                    type="Information"
                                    showCloseButton="false"
                                    class="sapUiSmallMarginBottom"
                                    visible="{= !${calc>/calculated} }"/>

                                <!-- Results shown after calculation -->
                                <HBox id="collCalcResults" wrap="Wrap" alignItems="Start" visible="{calc>/calculated}">

                                    <VBox id="collGrossVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="13rem">
                                        <Label id="collGrossLabel" text="{i18n>labelGrossAmount}" design="Bold"/>
                                        <ObjectNumber id="collGrossNum" number="{calc>/grossAmount}" unit="SAR"/>
                                    </VBox>

                                    <VBox id="collDiscPctVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                        <Label id="collDiscPctLabel" text="{i18n>labelDiscountPercent}" design="Bold"/>
                                        <ObjectNumber id="collDiscPctNum" number="{calc>/discountPercent}" unit="%"/>
                                    </VBox>

                                    <VBox id="collDiscAmtVBox" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="13rem">
                                        <Label id="collDiscAmtLabel" text="{i18n>labelDiscountAmount}" design="Bold"/>
                                        <ObjectNumber id="collDiscAmtNum" number="{calc>/discountAmount}" unit="SAR" state="Warning"/>
                                    </VBox>

                                    <VBox id="collNetVBox" class="sapUiSmallMarginBottom" width="13rem">
                                        <Label id="collNetLabel" text="{i18n>labelNetAmount}" design="Bold"/>
                                        <ObjectNumber id="collNetNum" number="{calc>/netAmount}" unit="SAR" state="Success"/>
                                    </VBox>

                                </HBox>

                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- ─── Card 3: Cases by Modality (April 2026) ─── -->
                    <f:Card id="collCasesCard" width="100%" class="sapUiSmallMarginTop" visible="{= ${cases>/loaded} }">
                        <f:header>
                            <card:Header id="collCasesHeader"
                                title="{i18n>casesByModalityTitle}"
                                subtitle="{i18n>casesByModalitySubtitle}"
                                iconSrc="sap-icon://clinical-order"
                                iconDisplayShape="Square"
                                iconBackgroundColor="Accent2"/>
                        </f:header>
                        <f:content>
                            <Table id="collCasesTable"
                                items="{cases>/items}"
                                class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"
                                noDataText="{i18n>noCases}">
                                <columns>
                                    <Column id="colCasesModalityIDCol">
                                        <Text id="_IDGenText13" text="{i18n>colCasesModalityID}"/>
                                    </Column>
                                    <Column id="colCasesTotalQtyCol" hAlign="End">
                                        <Text id="_IDGenText14" text="{i18n>colCasesTotalQty}"/>
                                    </Column>
                                    <Column id="colCasesPriceCol" hAlign="End">
                                        <Text id="_IDGenText15" text="{i18n>colCasesPrice}"/>
                                    </Column>
                                    <Column id="colCasesModalityGroupCol">
                                        <Text id="_IDGenText16" text="{i18n>colCasesModalityGroup}"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem3"
                                        type="{= ${mode>/isCreate} ? 'Active' : 'Inactive' }"
                                        press="onCasesRowSelect">
                                        <cells>
                                            <ObjectStatus id="_IDGenObjectStatus2" text="{cases>modalityID}" state="Information"/>
                                            <ObjectNumber id="_IDGenObjectNumber5" number="{cases>totalQty}" unit="cases" state="Success"/>
                                            <ObjectNumber id="_IDGenObjectNumber6" number="{cases>priceWithoutTax}" unit="SAR" state="None"/>
                                            <ObjectStatus id="_IDGenObjectStatus3" text="{cases>modalityGroup}" state="Success"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </f:content>
                    </f:Card>

                </VBox>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
